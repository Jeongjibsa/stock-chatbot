{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@stock-chatbot/application": ["packages/application/src/index.ts"],
      "@stock-chatbot/core-types": ["packages/core-types/src/index.ts"],
      "@stock-chatbot/database": ["packages/database/src/index.ts"],
      "@stock-chatbot/telegram-bot/build-bot": ["apps/telegram-bot/src/build-bot.ts"],
      "@stock-chatbot/worker/run-daily-report": ["apps/worker/src/run-daily-report.ts"],
      "@stock-chatbot/worker/run-public-briefing": ["apps/worker/src/run-public-briefing.ts"]
    }
  }
}
