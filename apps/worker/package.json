{
  "name": "@stock-chatbot/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "run:daily-report": "tsx src/run-daily-report.ts",
    "run:import-tickers": "tsx src/import-ticker-master.ts",
    "run:public-briefing": "tsx src/run-public-briefing.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@stock-chatbot/application": "workspace:*",
    "@stock-chatbot/database": "workspace:*",
    "bullmq": "5.58.5",
    "dotenv": "17.2.2",
    "ioredis": "5.8.0"
  },
  "devDependencies": {
    "tsx": "4.20.5"
  }
}
