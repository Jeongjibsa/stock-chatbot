{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/cron/pre-market-briefing",
      "schedule": "30 22 * * 0-5"
    },
    {
      "path": "/api/cron/post-market-briefing",
      "schedule": "30 11 * * 1-5"
    }
  ]
}
