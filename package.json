{
  "name": "stock-chatbot",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "build": "pnpm -r build",
    "dev:api": "pnpm --filter @stock-chatbot/api dev",
    "dev:bot": "pnpm --filter @stock-chatbot/telegram-bot dev",
    "dev:web": "pnpm --filter @stock-chatbot/web dev",
    "dev:worker": "pnpm --filter @stock-chatbot/worker dev",
    "e2e:final": "node scripts/e2e/run-final-validation.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "harness:check": "pnpm harness:fixtures && pnpm harness:snapshots",
    "harness:fixtures": "node scripts/harness/validate-fixtures.mjs",
    "harness:snapshots": "node scripts/harness/compare-snapshots.mjs",
    "lint": "eslint .",
    "pages:build": "node scripts/pages/build-public-briefing.mjs",
    "tickers:import": "pnpm --filter @stock-chatbot/worker run run:import-tickers",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:telegram:e2e": "pnpm --filter @stock-chatbot/telegram-bot run e2e",
    "telegram:webhook:register": "node scripts/telegram/register-webhook.mjs",
    "test:telegram": "pnpm --filter @stock-chatbot/telegram-bot run smoke",
    "test:watch": "vitest",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm harness:check && docker compose config -q && docker compose --profile app config -q",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.34.0",
    "@next/eslint-plugin-next": "15.5.14",
    "@types/node": "24.3.0",
    "@types/pg": "8.15.5",
    "@typescript-eslint/eslint-plugin": "8.41.0",
    "@typescript-eslint/parser": "8.41.0",
    "eslint": "9.34.0",
    "globals": "16.3.0",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  }
}
